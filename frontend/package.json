{
    "name": "vkquiz-frontend",
    "private": true,
    "version": "0.0.1",
    "type": "module",
    "scripts": {
        "prepare": "cd .. && git config core.hooksPath .husky",
        "dev": "vite",
        "build": "tsc -b && vite build",
        "preview": "vite preview",
        "check:circular": "node scripts/check-circular.mjs",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier . --write",
        "format:check": "prettier . --check",
        "check": "npm run lint && npm run format:check && npm run check:circular && npm run test:run && npm run test:e2e",
        "test": "vitest",
        "test:run": "vitest run",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest run --coverage",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "generate:api": "orval --config orval.config.ts"
    },
    "dependencies": {
        "@radix-ui/react-accordion": "1.2.3",
        "@radix-ui/react-alert-dialog": "1.1.6",
        "@radix-ui/react-avatar": "1.1.3",
        "@radix-ui/react-checkbox": "1.1.4",
        "@radix-ui/react-collapsible": "1.1.3",
        "@radix-ui/react-dialog": "1.1.6",
        "@radix-ui/react-dropdown-menu": "2.1.6",
        "@radix-ui/react-label": "2.1.2",
        "@radix-ui/react-popover": "1.1.6",
        "@radix-ui/react-progress": "1.1.2",
        "@radix-ui/react-radio-group": "1.2.3",
        "@radix-ui/react-scroll-area": "1.2.3",
        "@radix-ui/react-select": "2.1.6",
        "@radix-ui/react-separator": "1.1.2",
        "@radix-ui/react-slider": "1.2.3",
        "@radix-ui/react-slot": "1.1.2",
        "@radix-ui/react-switch": "1.1.3",
        "@radix-ui/react-tabs": "1.1.3",
        "@radix-ui/react-tooltip": "1.1.8",
        "canvas-confetti": "1.9.4",
        "clsx": "2.1.1",
        "lucide-react": "0.487.0",
        "mobx": "6.13.5",
        "mobx-react-lite": "4.1.0",
        "react": "18.3.1",
        "react-dom": "18.3.1",
        "react-router": "7.13.0",
        "sonner": "2.0.3"
    },
    "devDependencies": {
        "@eslint/js": "^9.24.0",
        "@playwright/test": "^1.59.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/canvas-confetti": "1.9.0",
        "@types/node": "^25.6.0",
        "@types/react": "18.3.18",
        "@types/react-dom": "18.3.5",
        "@vitejs/plugin-react": "4.7.0",
        "@vitest/coverage-v8": "^4.1.4",
        "@vitest/ui": "^4.1.4",
        "eslint": "^9.24.0",
        "eslint-config-prettier": "^10.1.2",
        "eslint-plugin-prettier": "^5.2.6",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-react-refresh": "^0.4.19",
        "eslint-plugin-simple-import-sort": "^12.1.1",
        "globals": "^16.0.0",
        "happy-dom": "^20.8.9",
        "husky": "^9.1.7",
        "jiti": "^2.4.2",
        "madge": "8.0.0",
        "orval": "^8.8.1",
        "prettier": "^3.5.3",
        "sass": "1.86.3",
        "typescript": "5.7.3",
        "typescript-eslint": "^8.30.1",
        "vite": "6.3.5",
        "vitest": "^4.1.4"
    }
}
