{
    "tsConfig": "tsconfig.json",
    "includeNpm": false,
    "fileExtensions": ["ts", "tsx"],
    "excludeRegExp": [".*\\.scss$", ".*\\.css$"],
    "detectiveOptions": {
        "ts": {
            "skipTypeImports": true
        },
        "tsx": {
            "skipTypeImports": true
        }
    }
}
